{
  "version": 2,
  "installCommand": "npm install && npm run db:generate -w @astralhq/server",
  "buildCommand": "npm run build -w @astralhq/client",
  "outputDirectory": "apps/client/dist",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
