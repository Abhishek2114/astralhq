{
  "version": 2,
  "installCommand": "npm install && npm install -w @astralhq/client && npm run db:generate -w @astralhq/server",
  "buildCommand": "npm run build -w @astralhq/client",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 10, "runtime": "nodejs20.x" }
    },
    {
      "src": "apps/client/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/apps/client/dist/index.html" }
  ]
}
